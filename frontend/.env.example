# Copy to frontend/.env for local dev (gitignored).
# For production, set these before `npm run build` or in AWS Amplify env vars.

# JSON API base URL (no trailing slash). Must include /api/v1.
NUXT_PUBLIC_API_BASE_URL=http://localhost:21080/api/v1

# Production example:
# NUXT_PUBLIC_API_BASE_URL=https://api.merchflow.org/api/v1

# Stripe publishable key only (pk_test_… / pk_live_…)
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
